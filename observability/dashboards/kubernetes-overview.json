{
  "title": "Kubernetes Overview",
  "panels": [
    {
      "title": "Running Pods",
      "type": "stat",
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{phase=\"Running\"})"
        }
      ]
    },
    {
      "title": "Pod Restarts",
      "type": "timeseries",
      "targets": [
        {
         "expr": "sum(increase(kube_pod_container_status_restarts_total[5m]))"
        }
      ]
    },
    {
      "title": "Deployment Replicas",
      "type": "timeseries",
      "targets": [
        {
          "expr": "kube_deployment_status_replicas"
        }
      ]
    }
  ]
}
